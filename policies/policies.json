        "allowed_tickers": [
          "AAPL", "MSFT", "NVDA", "GOOGL", "META", "AMZN", "AMD",
          "AVGO", "QCOM", "CRM", "ADBE", "NOW", "SNOW", "PLTR", "PANW",
          "ZS", "DDOG", "MDB", "COIN", "RBLX"
